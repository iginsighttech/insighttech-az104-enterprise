{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "5136002150382316043"
    }
  },
  "parameters": {
    "rgName": {
      "type": "string"
    }
  },
  "variables": {
    "requireEnvTagPolicyName": "require-env-tag-rg",
    "requireEnvAssignmentName": "assign-require-env-tag-audit"
  },
  "resources": [
    {
      "type": "Microsoft.Authorization/policyDefinitions",
      "apiVersion": "2021-06-01",
      "name": "[variables('requireEnvTagPolicyName')]",
      "properties": {
        "displayName": "Require Environment tag on resource groups",
        "policyType": "Custom",
        "mode": "All",
        "description": "Ensures RGs have a non-empty Environment tag.",
        "parameters": {
          "effect": {
            "type": "String",
            "allowedValues": [
              "Audit",
              "Deny"
            ],
            "defaultValue": "Audit"
          }
        },
        "policyRule": {
          "if": {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Resources/subscriptions/resourceGroups"
              },
              {
                "anyOf": [
                  {
                    "field": "tags[\"Environment\"]",
                    "exists": false
                  },
                  {
                    "field": "tags[\"Environment\"]",
                    "equals": ""
                  }
                ]
              }
            ]
          },
          "then": {
            "effect": "[[parameters(\"effect\")]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Authorization/policyAssignments",
      "apiVersion": "2021-06-01",
      "name": "[variables('requireEnvAssignmentName')]",
      "properties": {
        "displayName": "Require Environment tag on RGs (Audit)",
        "policyDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/policyDefinitions', variables('requireEnvTagPolicyName'))]",
        "parameters": {
          "effect": {
            "value": "Audit"
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Authorization/policyDefinitions', variables('requireEnvTagPolicyName'))]"
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "apply-rg-cannotdelete-lock",
      "resourceGroup": "[parameters('rgName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "lockName": {
            "value": "lock-rg-cannotdelete"
          },
          "lockNotes": {
            "value": "AZ-104 lab: prevent accidental deletion"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "4533159660886562141"
            }
          },
          "parameters": {
            "lockName": {
              "type": "string",
              "defaultValue": "lock-rg-cannotdelete"
            },
            "lockNotes": {
              "type": "string",
              "defaultValue": "AZ-104 lab: prevent accidental deletion"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Authorization/locks",
              "apiVersion": "2016-09-01",
              "name": "[parameters('lockName')]",
              "properties": {
                "level": "CanNotDelete",
                "notes": "[parameters('lockNotes')]"
              }
            }
          ]
        }
      }
    }
  ]

{
  "$schema": "https://schema.management.azure.com/schemas/2019-08-01/tenantDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "8930258987263362475"
    }
  },
  "parameters": {
    "rootMgName": {
      "type": "string",
      "defaultValue": "mg-az104-root",
      "metadata": {
        "description": "Root management group name."
      }
    },
    "childMgs": {
      "type": "array",
      "defaultValue": [
        "mg-az104-platform",
        "mg-az104-workloads",
        "mg-az104-sandbox"
      ],
      "metadata": {
        "description": "Child management groups."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Management/managementGroups",
      "apiVersion": "2021-04-01",
      "name": "[parameters('rootMgName')]"
    },
    {
      "copy": {
        "name": "children",
        "count": "[length(parameters('childMgs'))]"
      },
      "type": "Microsoft.Management/managementGroups",
      "apiVersion": "2021-04-01",
      "name": "[parameters('childMgs')[copyIndex()]]",
      "properties": {
        "details": {
          "parent": {
            "id": "[tenantResourceId('Microsoft.Management/managementGroups', parameters('rootMgName'))]"
          }
        }
      },
      "dependsOn": [
        "[tenantResourceId('Microsoft.Management/managementGroups', parameters('rootMgName'))]"
      ]
    }
  ]
}